// Sim-only aperture setpoint for one openarm gripper, addressed by `gripper_id`.
// Internal sim plumbing; the robot's command surface is the gripper_link pairing.
{
  peppy_schema: "contract/v1",
  manifest: {
    name: "openarm_gripper_sim_passthrough",
    tag: "v1",
  },
  interfaces: {
    topics: [
      {
        name: "gripper_sim_passthrough",
        qos_profile: "sensor_data",
        message_format: {
          // Which gripper (0 = left, 1 = right).
          gripper_id: "u8",
          // Desired opening as a fraction of full jaw travel: 0 = closed,
          // 1 = fully open.
          opening: "f64"
        }
      }
    ]
  }
}
