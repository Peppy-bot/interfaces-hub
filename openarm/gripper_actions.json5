// Goal-based gripper motion for openarm: the move_gripper action, a discrete
// goal that returns a result. Distinct from the openarm_gripper_commands stream.
{
  peppy_schema: "interface/v1",
  manifest: {
    name: "openarm_gripper_actions",
    tag: "v1"
  },
  interfaces: {
    actions: [
      {
        name: "move_gripper",
        goal_service: {
          request_message_format: {
            // Target gripper opening (m): 0.0 = closed, 0.044 = fully open on V1.0.
            position: "f64"
          }
        },
        result_service: {
          response_message_format: {
            // Whether the move ran to completion.
            success: "bool",
            message: "string",
            // Measured finger joint positions (rad) when the action ended.
            final_joint_positions: {
              $type: "array",
              $items: "f64"
            },
            // Wall-clock duration of the action (s).
            action_time: "f64"
          }
        }
      }
    ]
  }
}
