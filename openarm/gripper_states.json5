// Measured opening of one openarm gripper, addressed by `gripper_id`.
{
  peppy_schema: "interface/v1",
  manifest: {
    name: "openarm_gripper_states",
    tag: "v1",
  },
  interfaces: {
    topics: [
      {
        name: "gripper_states",
        qos_profile: "sensor_data",
        message_format: {
          // Which gripper (0 = left, 1 = right).
          gripper_id: "u8",
          // Measured opening (m): 0.0 = closed, increasing toward fully open.
          position: "f64",
          // Measured grip force, from the gripper motor's torque estimate (N·m at the
          // motor shaft). 0.0 when the gripper does not sense force.
          force: "f64"
        }
      }
    ]
  }
}
