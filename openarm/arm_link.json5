// The exclusive control conversation between one commander instance and ONE
// openarm arm, as a pairing: the commander streams the governed joint setpoint
// and the arm streams its measured joint state back, both directions scoped to
// the pair, so there is no arm_id demux and no other producer can drive the arm
// or pose as its state. Pairs are established at instance start (`--pair` /
// launcher `pairings:`) and dissolve automatically when either endpoint dies;
// the survivor's slot goes silent until a new peer is paired.
//
// The always-on broadcast `openarm_arm_states` interface remains the observer
// surface; this pairing is the exclusive command loop.
{
  peppy_schema: "pairing/v1",
  manifest: {
    name: "openarm_arm_link",
    tag: "v1",
  },
  roles: ["commander", "arm"],
  topics: [
    {
      emitted_by: "commander",
      name: "arm_setpoints",
      // High-frequency stream where only the latest setpoint matters;
      // occasional drops are acceptable.
      qos_profile: "sensor_data",
      message_format: {
        // Desired joint positions (rad), j1..j7.
        positions: {
          $type: "array",
          $items: "f64",
          $length: 7
        },
        // Desired joint velocities (rad/s), j1..j7 (feedforward).
        velocities: {
          $type: "array",
          $items: "f64",
          $length: 7
        }
      }
    },
    {
      emitted_by: "arm",
      name: "arm_states",
      // High-frequency stream where only the latest state matters;
      // occasional drops are acceptable.
      qos_profile: "sensor_data",
      message_format: {
        // Measured joint positions (rad), j1..j7.
        positions: {
          $type: "array",
          $items: "f64",
          $length: 7
        },
        // Measured joint velocities (rad/s), j1..j7.
        velocities: {
          $type: "array",
          $items: "f64",
          $length: 7
        }
      }
    }
  ]
}
