// Streamed joint position commands for one openarm arm, addressed by `arm_id`.
{
  peppy_schema: "interface/v1",
  manifest: {
    name: "openarm_arm_joint_commands",
    tag: "v1",
  },
  interfaces: {
    topics: [
      {
        name: "arm_joint_commands",
        qos_profile: "sensor_data",
        message_format: {
          // Which arm (0 = left, 1 = right).
          arm_id: "u8",
          // Target joint positions (rad), j1..j7. No velocity is commanded.
          positions: {
            $type: "array",
            $items: "f64",
            $length: 7
          }
        }
      }
    ]
  }
}
