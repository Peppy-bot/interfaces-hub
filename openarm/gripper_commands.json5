// Streamed opening commands for one openarm gripper, addressed by `gripper_id`.
{
  peppy_schema: "interface/v1",
  manifest: {
    name: "openarm_gripper_commands",
    tag: "v1",
  },
  interfaces: {
    topics: [
      {
        name: "gripper_commands",
        qos_profile: "sensor_data",
        message_format: {
          // Which gripper (0 = left, 1 = right).
          gripper_id: "u8",
          // Target opening (m): 0.0 = closed, 0.044 = fully open on V1.0.
          position: "f64"
        }
      }
    ]
  }
}
