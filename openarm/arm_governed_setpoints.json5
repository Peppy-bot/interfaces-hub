// Collision-governed joint setpoint for one openarm arm: target positions and
// velocity feedforward, addressed by `arm_id`.
{
  peppy_schema: "interface/v1",
  manifest: {
    name: "openarm_arm_governed_setpoints",
    tag: "v1",
  },
  interfaces: {
    topics: [
      {
        name: "arm_governed_setpoints",
        qos_profile: "sensor_data",
        message_format: {
          // Which arm (0 = left, 1 = right).
          arm_id: "u8",
          // Desired joint positions (rad), j1..j7.
          positions: {
            $type: "array",
            $items: "f64",
            $length: 7
          },
          // Desired joint velocities (rad/s), j1..j7 (feedforward).
          velocities: {
            $type: "array",
            $items: "f64",
            $length: 7
          }
        }
      }
    ]
  }
}
