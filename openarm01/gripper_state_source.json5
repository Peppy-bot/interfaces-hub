// Measured opening of one openarm01 gripper, emitted continuously at the
// gripper's `state_rate_hz` regardless of mode. The return direction of the
// gripper's bidirectional stream pattern, mirroring openarm01_joint_state_source
// for the arm: a teleop or monitoring node consumes it through a `from_any`
// dependency and tells grippers apart by `gripper_id`.
{
  peppy_schema: "interface_v1",
  manifest: {
    name: "openarm01_gripper_state_source",
    tag: "v1",
  },
  interfaces: {
    topics: [
      {
        name: "gripper_states",
        // High-frequency stream where only the latest state matters;
        // occasional drops are acceptable.
        qos_profile: "sensor_data",
        message_format: {
          // Which gripper this state describes (0 = left, 1 = right).
          gripper_id: "u8",
          // Measured opening (m), matching the move_gripper command unit:
          // 0.0 = closed, ~0.044 = fully open on V1.0. Not the per-finger joint
          // positions; this is the single aperture value.
          position: "f64"
        }
      }
    ]
  }
}
