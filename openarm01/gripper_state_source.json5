// Measured opening of one openarm01 gripper, addressed by `gripper_id`. Emitted
// continuously at the gripper's `state_rate_hz`; consumed via `from_any`. The
// return direction of openarm01_gripper_command_source.
{
  peppy_schema: "interface/v1",
  manifest: {
    name: "openarm01_gripper_state_source",
    tag: "v1",
  },
  interfaces: {
    topics: [
      {
        name: "gripper_states",
        qos_profile: "sensor_data",
        message_format: {
          // Which gripper (0 = left, 1 = right).
          gripper_id: "u8",
          // Measured opening (m): 0.0 = closed, 0.044 = fully open on V1.0.
          position: "f64"
        }
      }
    ]
  }
}
