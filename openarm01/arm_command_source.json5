// Streamed joint commands for one openarm01 arm, addressed by `arm_id`. A producer
// (teleop leader, planner, calibration script) conforms to this; the return
// direction is openarm01_arm_state_source.
{
  peppy_schema: "interface/v1",
  manifest: {
    name: "openarm01_arm_command_source",
    tag: "v1",
  },
  interfaces: {
    topics: [
      {
        name: "arm_commands",
        qos_profile: "sensor_data",
        message_format: {
          // Which arm (0 = left, 1 = right).
          arm_id: "u8",
          // Target joint positions (rad), j1..j7. No velocity is commanded.
          positions: {
            $type: "array",
            $items: "f64",
            $length: 7
          }
        }
      }
    ]
  }
}
