// Streamed joint-space setpoints for one openarm01 arm. A producer (teleop
// leader, planner, calibration script) conforms to this interface and emits
// `joint_commands` continuously; the arm follows them whenever no move is
// running, locking to the first producer instance it sees. The lock releases
// two ways, so producers can fail over and hand off: a move_arm/move_arm_joints
// goal preempts the stream (the arm resumes following when the move ends), and
// the arm drops the lock once its configured stream timeout passes with no new
// message, freeing it for a replacement producer if the current one dies or
// stalls. Messages carry the target `arm_id` so one producer can drive either
// arm and each arm ignores commands addressed to the other.
{
  peppy_schema: "interface/v1",
  manifest: {
    name: "openarm01_joint_command_source",
    tag: "v1",
  },
  interfaces: {
    topics: [
      {
        name: "joint_commands",
        // High-frequency stream where only the latest setpoint matters;
        // occasional drops are acceptable.
        qos_profile: "sensor_data",
        message_format: {
          // Which arm this command addresses (0 = left, 1 = right).
          arm_id: "u8",
          // Desired joint positions (rad), j1..j7. The arm clamps them to its
          // URDF joint limits and rate-limits its setpoint toward them at its
          // per-joint velocity limits; the velocity feedforward is derived from
          // that chase, so a dense position stream needs no separate velocity.
          positions: {
            $type: "array",
            $items: "f64",
            $length: 7
          }
        }
      }
    ]
  }
}
