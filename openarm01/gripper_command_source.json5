// Streamed opening setpoints for one openarm01 gripper, addressed by `gripper_id`.
// A producer (teleop leader, planner, calibration script) conforms to this; the
// return direction is openarm01_gripper_state_source.
{
  peppy_schema: "interface/v1",
  manifest: {
    name: "openarm01_gripper_command_source",
    tag: "v1",
  },
  interfaces: {
    topics: [
      {
        name: "gripper_commands",
        qos_profile: "sensor_data",
        message_format: {
          // Which gripper (0 = left, 1 = right).
          gripper_id: "u8",
          // Target opening (m): 0.0 = closed, 0.044 = fully open on V1.0.
          position: "f64"
        }
      }
    ]
  }
}
