// Sim-only: the actuator setpoint an openarm01 arm node hands to the simulation
// engine, addressed by `arm_id`. Not the public command contract; that is
// openarm01_arm_command_source.
{
  peppy_schema: "interface/v1",
  manifest: {
    name: "openarm01_arm_sim_passthrough",
    tag: "v1",
  },
  interfaces: {
    topics: [
      {
        name: "arm_sim_passthrough",
        qos_profile: "sensor_data",
        message_format: {
          // Which arm (0 = left, 1 = right).
          arm_id: "u8",
          // Desired joint positions (rad), j1..j7.
          positions: {
            $type: "array",
            $items: "f64",
            $length: 7
          },
          // Desired joint velocities (rad/s), j1..j7 (feedforward).
          velocities: {
            $type: "array",
            $items: "f64",
            $length: 7
          }
        }
      }
    ]
  }
}
