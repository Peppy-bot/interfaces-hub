{
  // Readiness signal every robot_initializer implementation exposes. Backbone polls
  // is_ready and waits for ready:true before doing anything; the real implementation
  // aggregates per-component openarm01_hardware_ready signals (ready:true once every
  // arm/gripper has enabled its motors) and sim implementations return ready:false
  // while the sim loads, ready:true once the scene is ready. Lets backbone be
  // sim/real agnostic.
  peppy_schema: "interface/v1",
  manifest: {
    name: "openarm01_robot_initializer",
    tag: "v1"
  },
  interfaces: {
    services: [
      {
        name: "is_ready",
        response_message_format: {
          ready: "bool"
        }
      }
    ]
  }
}
