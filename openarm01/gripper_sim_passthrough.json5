// Sim-only: the aperture an openarm01 gripper node hands to the simulation engine,
// addressed by `gripper_id`. Not the public command contract; that is
// openarm01_gripper_command_source.
{
  peppy_schema: "interface/v1",
  manifest: {
    name: "openarm01_gripper_sim_passthrough",
    tag: "v1",
  },
  interfaces: {
    topics: [
      {
        name: "gripper_sim_passthrough",
        qos_profile: "sensor_data",
        message_format: {
          // Which gripper (0 = left, 1 = right).
          gripper_id: "u8",
          // Desired opening (m): 0.0 = closed, 0.044 = fully open on V1.0.
          position: "f64"
        }
      }
    ]
  }
}
