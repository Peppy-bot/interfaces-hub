// RGB-D camera contract: a device that emits synchronized color + depth
// streams (e.g. Intel RealSense D4xx, or a simulated/mock RGB-D node). Color
// and depth share a frame_id (a capture-pair counter, not a coordinate frame)
// so consumers can correlate paired frames without timestamp matching. Cameras
// that emit only color implement rgb_camera. Depth-derived stereo IR and IMU
// streams are out of scope; an implementation exposing them should implement
// an additional contract for those. Device-specific hardware knobs (depth
// sensor gain, laser projector power, runtime re-alignment) are native
// services on the implementing node, not contract members: the contract only
// carries what every RGB-D device can honor. Frame alignment stays visible as
// data through each stream header's align_mode field.
{
  peppy_schema: "contract/v1",
  manifest: {
    name: "rgbd_camera",
    tag: "v1"
  },
  interfaces: {
    topics: [
      {
        name: "video_stream",
        qos_profile: "sensor_data",
        message_format: {
          header: {
            $type: "object",
            stamp: "time",
            frame_id: "u32",
            align_mode: "string",   // e.g. "none" | "depth_to_color" | "color_to_depth"
          },
          encoding: "string",   // e.g. "rgb8" | "bgr8" | "yuyv" | "mjpeg"
          width: "u32",
          height: "u32",
          frame: {
            $type: "array",
            $items: "u8",
          },
        },
      },
      {
        name: "depth_stream",
        qos_profile: "sensor_data",
        message_format: {
          header: {
            $type: "object",
            stamp: "time",
            frame_id: "u32",
            align_mode: "string",   // e.g. "none" | "depth_to_color" | "color_to_depth"
          },
          encoding: "string",   // e.g. "z16" (u16 little-endian)
          width: "u32",
          height: "u32",
          frame: {
            $type: "array",
            $items: "u8",
          },
        },
      },
    ],
    services: [
      {
        name: "video_stream_info",
        response_message_format: {
          width: "u32",
          height: "u32",
          frames_per_second: "u8",
          encoding: "string",
        }
      },
      {
        name: "depth_stream_info",
        response_message_format: {
          width: "u32",
          height: "u32",
          frames_per_second: "u8",
          encoding: "string",
          depth_unit: "f32",   // meters per LSB, e.g. 0.001 = 1mm
        }
      },
      {
        name: "set_color_exposure",
        request_message_format: {
          mode: "string",   // "auto" | "manual"
          value: "i32",     // microseconds (used when mode = "manual")
        },
        response_message_format: {
          success: "bool",
          message: "string",
          current_value: "i32",
        },
      },
      {
        name: "set_color_white_balance",
        request_message_format: {
          mode: "string",        // "auto" | "manual"
          temperature: "i32",    // Kelvin (used when mode = "manual")
        },
        response_message_format: {
          success: "bool",
          message: "string",
          current_temperature: "i32",
        },
      },
      {
        name: "set_color_gain",
        request_message_format: { value: "i32" },
        response_message_format: {
          success: "bool",
          message: "string",
          current_value: "i32",
        },
      },
      {
        name: "set_color_brightness",
        request_message_format: { value: "i32" },
        response_message_format: {
          success: "bool",
          message: "string",
          current_value: "i32",
        },
      },
      {
        name: "set_color_contrast",
        request_message_format: { value: "i32" },
        response_message_format: {
          success: "bool",
          message: "string",
          current_value: "i32",
        },
      },
    ]
  }
}
