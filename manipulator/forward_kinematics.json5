// Forward kinematics for a serial robot: joint positions to end-effector pose.
// Fully generic: needs only the chain geometry (no masses or inertials) and
// works at any DOF (joint count unspecified). The pose is world-frame; the
// quaternion is ordered [x, y, z, w].
{
  peppy_schema: "interface_v1",
  manifest: {
    name: "forward_kinematics",
    tag: "v1",
  },
  interfaces: {
    services: [
      {
        name: "get_fk",
        request_message_format: {
          joint_positions: { $type: "array", $items: "f64" },
        },
        response_message_format: {
          position: { $type: "array", $items: "f64", $length: 3 },
          orientation: { $type: "array", $items: "f64", $length: 4 }, // quat xyzw
        },
      },
    ],
  },
}
