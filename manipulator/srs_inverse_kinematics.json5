// Inverse kinematics for a 7-DOF SRS (spherical-revolute-spherical) arm:
// closed-form arm-angle solve. Opinionated by design, unlike forward_kinematics
// and compensation which are generic: the redundant DOF is parameterized by the
// arm angle (shoulder-elbow-wrist convention), which assumes a 7-DOF redundant
// SRS-style arm. Target pose is world-frame; quaternions are ordered [x, y, z, w].
{
  peppy_schema: "interface_v1",
  manifest: {
    name: "srs_inverse_kinematics",
    tag: "v1",
  },
  interfaces: {
    services: [
      {
        name: "get_ik",
        request_message_format: {
          target_position: { $type: "array", $items: "f64", $length: 3 },
          target_orientation: { $type: "array", $items: "f64", $length: 4 }, // quat xyzw
          // Reference joint configuration (length matches the arm's DOF), e.g. the
          // previous solution when servoing. Used to pick among IK branches
          // (typically the solution nearest the seed) and, with arm_angle_policy
          // "from_seed", to carry the seed's arm angle for continuity.
          seed: { $type: "array", $items: "f64" },
          // Redundancy resolution via the arm angle. peppy does not enforce string
          // values, so the provider validates; the conventions are:
          //   "from_seed" : use the seed's arm angle (continuity; arm_angle ignored)
          //   "fixed"     : use the arm_angle field
          arm_angle_policy: "string",
          arm_angle: "f64", // radians; used with the "fixed" policy
        },
        response_message_format: {
          success: "bool",
          joint_positions: { $type: "array", $items: "f64" },
          arm_angle: "f64", // the arm angle the solution was built at
          message: "string",
        },
      },
    ],
  },
}
